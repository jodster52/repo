# Copy to `.env` (shared defaults) and/or `.env.<environment>` files.
# The active environment is selected with the ENV variable:
#   cross-env ENV=qa playwright test   ->  loads .env then .env.qa

# --- Application under test ---
BASE_URL=http://localhost:3000
API_URL=http://localhost:3000/api

# --- Credentials (prefer real secrets via CI secret store, not committed files) ---
APP_USERNAME=
APP_PASSWORD=

# --- Run behavior ---
HEADLESS=true
TIMEOUT=30000
RETRIES=0
# WORKERS=4

# --- Self-healing ---
HEALING_ENABLED=true
HEALING_PERSIST=true
HEALING_STORE=healing/locator-store.json
